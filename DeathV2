-- // ========== DETEKSI REMOTE EVENTS ==========
-- Cari semua RemoteEvent/RemoteFunction di game
local remoteEvents = {}
local function findRemotes()
    for _, child in ipairs(ReplicatedStorage:GetDescendants()) do
        if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
            remoteEvents[child.Name] = child
            print("[DEBUG] Found remote:", child.Name)
        end
    end
    -- Cari juga di workspace atau tempat lain
    for _, child in ipairs(Workspace:GetDescendants()) do
        if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
            remoteEvents[child.Name] = child
            print("[DEBUG] Found remote in Workspace:", child.Name)
        end
    end
end
findRemotes()

-- // ========== FUNGSI UTAMA ==========
-- Fungsi untuk mendapatkan bola terdekat (dengan berbagai kemungkinan lokasi)
local function getNearestBall()
    local possibleParents = {
        Workspace:FindFirstChild("Balls"),
        Workspace:FindFirstChild("Projectiles"),
        Workspace:FindFirstChild("Ball"),
        Workspace:FindFirstChild("GameParts"),
        Workspace:FindFirstChild("Items")
    }
    
    local nearestBall = nil
    local nearestDist = math.huge
    
    for _, parent in ipairs(possibleParents) do
        if parent then
            for _, obj in ipairs(parent:GetChildren()) do
                if obj:IsA("BasePart") and obj.Parent ~= character then
                    local dist = (obj.Position - character.PrimaryPart.Position).Magnitude
                    if dist < nearestDist then
                        nearestDist = dist
                        nearestBall = obj
                    end
                end
            end
        end
    end
    return nearestBall
end

-- Fungsi untuk mendapatkan pemain musuh terdekat
local function getNearestEnemy()
    local nearestPlayer = nil
    local nearestDist = math.huge
    
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player and otherPlayer.Character then
            local dist = (otherPlayer.Character.PrimaryPart.Position - character.PrimaryPart.Position).Magnitude
            if dist < nearestDist then
                nearestDist = dist
                nearestPlayer = otherPlayer
            end
        end
    end
    return nearestPlayer
end

-- // ========== FITUR-FITUR ==========
-- 1. SMART AUTO PARRY
local autoParryEnabled = false
local function autoParry()
    if not autoParryEnabled then return end
    
    local ball = getNearestBall()
    if not ball then return end
    
    -- Cek apakah bola bergerak ke arah pemain
    local ballVel = ball:FindFirstChild("Velocity") or ball:FindFirstChild("LinearVelocity")
    if ballVel then
        local vel = ballVel.Value
        if vel.Magnitude > 10 then
            -- Cek arah bola
            local direction = (ball.Position - character.PrimaryPart.Position).Unit
            local dot = vel.Unit:Dot(direction)
            if dot > 0.8 then  -- Bola datang ke arah pemain
                -- Cari remote parry
                local parryRemote = remoteEvents["Parry"] or remoteEvents["Block"] or remoteEvents["Deflect"]
                if parryRemote then
                    parryRemote:FireServer()
                    return
                end
            end
        end
    end
end

-- 2. SMART AUTO SPAM
local autoSpamEnabled = false
local spamCount = 0
local function autoSpam()
    if not autoSpamEnabled then return end
    spamCount = spamCount + 1
    
    -- Spam setiap 2-4 frame (agar tidak terlalu cepat)
    if spamCount % math.random(2, 4) == 0 then
        local attackRemote = remoteEvents["Attack"] or remoteEvents["Swing"] or remoteEvents["Hit"]
        if attackRemote then
            attackRemote:FireServer()
        end
    end
end

-- 3. RANDOM CURVE
local randomCurveEnabled = false
local function randomCurve()
    if not randomCurveEnabled then return end
    
    local curveRemote = remoteEvents["Curve"] or remoteEvents["CurveDirection"] or remoteEvents["SetCurve"]
    if curveRemote then
        local x = math.random(-100, 100)
        local y = math.random(-100, 100)
        curveRemote:FireServer(x, y)
    end
end

-- 4. TARGET PLAYER CURVE
local targetCurveEnabled = false
local function targetPlayerCurve()
    if not targetCurveEnabled then return end
    
    local enemy = getNearestEnemy()
    if enemy then
        local curveRemote = remoteEvents["Curve"] or remoteEvents["CurveDirection"] or remoteEvents["SetCurve"]
        if curveRemote then
            local enemyPos = enemy.Character.PrimaryPart.Position
            local direction = (enemyPos - character.PrimaryPart.Position).Unit
            curveRemote:FireServer(direction.X * 100, direction.Z * 100)
        end
    end
end

-- 5. LEGIT MODE
local legitModeEnabled = false
local lastActionTime = 0
local function legitMode()
    if not legitModeEnabled then return end
    -- Simulasi human reaction time (100-300ms delay)
    local currentTime = tick()
    if currentTime - lastActionTime < math.random(0.1, 0.3) then
        return false
    end
    lastActionTime = currentTime
    return true
end

