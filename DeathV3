local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")

-- // ========== DETEKSI REMOTE EVENTS ==========
local remoteEvents = {}
local function findRemotes()
    local searchPlaces = {ReplicatedStorage, Workspace, player}
    for _, place in ipairs(searchPlaces) do
        for _, child in ipairs(place:GetDescendants()) do
            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                remoteEvents[child.Name] = child
            end
        end
    end
end
findRemotes()

-- // ========== FUNGSI UTAMA ==========
-- Fungsi untuk mendapatkan semua bola
local function getAllBalls()
    local balls = {}
    local possibleParents = {"Balls", "Projectiles", "Ball", "GameParts", "Items"}
    
    for _, name in ipairs(possibleParents) do
        local parent = Workspace:FindFirstChild(name)
        if parent then
            for _, obj in ipairs(parent:GetChildren()) do
                if obj:IsA("BasePart") and obj.Parent ~= character then
                    table.insert(balls, obj)
                end
            end
        end
    end
    
    -- Jika tidak ditemukan, cari semua BasePart di workspace
    if #balls == 0 then
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("BasePart") and obj.Parent ~= character and obj.Parent ~= workspace then
                if obj.Size.Magnitude > 2 and obj.Size.Magnitude < 10 then
                    table.insert(balls, obj)
                end
            end
        end
    end
    
    return balls
end

-- Fungsi untuk mendapatkan bola terdekat
local function getNearestBall()
    local balls = getAllBalls()
    local nearestBall = nil
    local nearestDist = math.huge
    
    for _, ball in ipairs(balls) do
        local dist = (ball.Position - character.PrimaryPart.Position).Magnitude
        if dist < nearestDist then
            nearestDist = dist
            nearestBall = ball
        end
    end
    
    return nearestBall
end

-- Fungsi untuk mendapatkan musuh terdekat
local function getNearestEnemy()
    local nearestPlayer = nil
    local nearestDist = math.huge
    
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player and otherPlayer.Character and otherPlayer.Character:FindFirstChild("Humanoid") then
            local dist = (otherPlayer.Character.PrimaryPart.Position - character.PrimaryPart.Position).Magnitude
            if dist < nearestDist then
                nearestDist = dist
                nearestPlayer = otherPlayer
            end
        end
    end
    
    return nearestPlayer
end

-- // ========== FITUR-FITUR ==========
-- 1. AUTO PARRY (Metode 1: Menggunakan VirtualUser)
local autoParryEnabled = false
local function autoParryVU()
    if not autoParryEnabled then return end
    pcall(function()
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end)
end

-- 1. AUTO PARRY (Metode 2: Menggunakan RemoteEvent)
local function autoParryRemote()
    if not autoParryEnabled then return end
    
    local ball = getNearestBall()
    if not ball then return end
    
    -- Cek jarak bola
    local dist = (ball.Position - character.PrimaryPart.Position).Magnitude
    if dist < 20 then
        local parryRemote = remoteEvents["Parry"] or remoteEvents["Block"] or remoteEvents["Deflect"] or remoteEvents["Shield"]
        if parryRemote then
            parryRemote:FireServer()
        end
    end
end

-- 2. AUTO SPAM
local autoSpamEnabled = false
local function autoSpam()
    if not autoSpamEnabled then return end
    
    local attackRemote = remoteEvents["Attack"] or remoteEvents["Swing"] or remoteEvents["Hit"] or remoteEvents["M1"]
    if attackRemote then
        attackRemote:FireServer()
    end
end

-- 3. AUTO CURVE
local autoCurveEnabled = false
local function autoCurve()
    if not autoCurveEnabled then return end
    
    local curveRemote = remoteEvents["Curve"] or remoteEvents["CurveDirection"] or remoteEvents["SetCurve"] or remoteEvents["CurveBall"]
    if curveRemote then
        local x = math.random(-100, 100)
        local y = math.random(-100, 100)
        curveRemote:FireServer(x, y)
    end
end

-- 4. AIM ASSIST (Target Player Curve)
local aimAssistEnabled = false
local function aimAssist()
    if not aimAssistEnabled then return end
    
    local enemy = getNearestEnemy()
    if enemy then
        local curveRemote = remoteEvents["Curve"] or remoteEvents["CurveDirection"] or remoteEvents["SetCurve"] or remoteEvents["CurveBall"]
        if curveRemote then
            local enemyPos = enemy.Character.PrimaryPart.Position
            local direction = (enemyPos - character.PrimaryPart.Position).Unit
            curveRemote:FireServer(direction.X * 100, direction.Z * 100)
        end
    end
end

