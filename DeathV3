-- // ========== MAIN LOOP ==========
RunService.Heartbeat:Connect(function()
    if not character or not humanoid or humanoid.Health <= 0 then
        return
    end
    
    -- Auto Parry (menggunakan kedua metode)
    if autoParryEnabled then
        autoParryVU()
        autoParryRemote()
    end
    
    -- Auto Spam (setiap 5 frame)
    if autoSpamEnabled then
        if tick() % 0.1 < 0.01 then
            autoSpam()
        end
    end
    
    -- Auto Curve (setiap 10 frame)
    if autoCurveEnabled then
        if tick() % 0.2 < 0.01 then
            autoCurve()
        end
    end
    
    -- Aim Assist (setiap 15 frame)
    if aimAssistEnabled then
        if tick() % 0.3 < 0.01 then
            aimAssist()
        end
    end
end)

