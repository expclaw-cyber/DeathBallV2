-- // ========== FITUR-FITUR ==========
local autoParry = false
local autoSpam = false
local autoCurve = false
local autoClaim = false
local statBooster = false

-- 1. AUTO PARRY (dari RemoteEvent)
local function doParry()
    if not autoParry then return end
    
    -- Method 1: VirtualUser
    pcall(function()
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end)
    
    -- Method 2: RemoteEvent (Call #1 dan #4)
    if MainRemote then
        -- Cari bola terdekat
        local ball = nil
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and obj.Size.Magnitude > 2 and obj.Size.Magnitude < 8 then
                if obj.Parent and obj.Parent.Name ~= player.Name then
                    ball = obj
                    break
                end
            end
        end
        
        if ball and character and character:FindFirstChild("HumanoidRootPart") then
            local dist = (ball.Position - character.HumanoidRootPart.Position).Magnitude
            if dist < 25 then
                MainRemote:FireServer(4, character.HumanoidRootPart) -- Call #1 style
            end
        end
    end
end

-- 2. AUTO SPAM (Action Based)
local spamCount = 0
local function doSpam()
    if not autoSpam then return end
    spamCount = spamCount + 1
    
    if spamCount % 3 == 0 and ActionRemote then
        -- Action Remote Call #1 style
        ActionRemote:FireServer("81be4dbe73f189f1", "BoxHit", Vector3.new(0, 0, 0), true)
    end
end

-- 3. AUTO CURVE (RemoteEvent)
local function doCurve()
    if not autoCurve then return end
    
    if MainRemote then
        -- Call #3 dan #6 style
        local direction = Vector3.new(math.random(-100, 100)/100, -0.01, math.random(-100, 100)/100)
        local power = math.random(80, 200)
        MainRemote:FireServer(5, direction, power)
    end
end

-- 4. AUTO CLAIM QUEST (InventoryChanged)
local function claimQuests()
    if not autoClaim or not InventoryChanged then return end
    
    -- Ambil data quest dari InventoryChanged
    -- Call #1-#6 dan #9 style
    local questData = {
        ["LiveOpsEvents.WheelSpinSpecial10.Quests"] = {
            ["Summon_1"] = {Current = 8, Required = 8, Claimed = false},
            ["Matches2_1"] = {Current = 30, Required = 30, Claimed = false},
            ["Wins_1"] = {Current = 12, Required = 12, Claimed = false},
            ["Matches_1"] = {Current = 2, Required = 2, Claimed = false},
            ["Playtime_1"] = {Current = 13500, Required = 13500, Claimed = false},
            ["Dash_1"] = {Current = 135, Required = 135, Claimed = false},
            ["Deflects_1"] = {Current = 600, Required = 600, Claimed = false},
            ["Kills_1"] = {Current = 45, Required = 45, Claimed = false},
            ["FriendMatch_1"] = {Current = 12, Required = 12, Claimed = false},
            ["Damage_1"] = {Current = 113, Required = 113, Claimed = false},
        }
    }
    
    -- Kirim InventoryChanged untuk claim quest
    local data = {
        [1] = {}, -- empty Champions data
        [2] = {
            ["LiveOpsEvents.WheelSpinSpecial10.Quests"] = questData["LiveOpsEvents.WheelSpinSpecial10.Quests"]
        }
    }
    InventoryChanged:FireServer(data[1], data[2])
end

-- 5. STAT BOOSTER
local function boostStats()
    if not statBooster then return end
    
    if InventoryChanged then
        -- Call #7 style: Tambah stat
        local statData = {
            ["Statistics.Playtime:Total"] = 99999,
            ["Statistics.Matches:Total"] = 9999,
            ["Statistics.Kills:Total"] = 9999,
            ["Statistics.Wins:Total"] = 9999,
            ["Statistics.Deaths:Total"] = 0,
        }
        InventoryChanged:FireServer({}, statData)
    end
end

